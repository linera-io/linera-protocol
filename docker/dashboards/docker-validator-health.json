    {
      "title": "Memory Usage vs Limit",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 0,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*limit.*"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    10
                  ]
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "custom.lineWidth",
                "value": 1
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{job=\"cadvisor\", instance=~\"$instance\", name=~\".+\", name!~\"cadvisor|alloy\"}",
          "legendFormat": "{{name}} usage",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "container_spec_memory_limit_bytes{job=\"cadvisor\", instance=~\"$instance\", name=~\".+\", name!~\"cadvisor|alloy\"} > 0",
          "legendFormat": "{{name}} limit",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "title": "Memory % of Limit",
      "type": "gauge",
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{job=\"cadvisor\", instance=~\"$instance\", name=~\".+\", name!~\"cadvisor|alloy\"} / container_spec_memory_limit_bytes{job=\"cadvisor\", instance=~\"$instance\", name=~\".+\", name!~\"cadvisor|alloy\"} > 0",
          "legendFormat": "{{name}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "title": "Memory Usage % Over Time (OOM danger > 90%)",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "spanNulls": true,
            "thresholdsStyle": {
              "mode": "area"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{job=\"cadvisor\", instance=~\"$instance\", name=~\".+\", name!~\"cadvisor|alloy\"} / container_spec_memory_limit_bytes{job=\"cadvisor\", instance=~\"$instance\", name=~\".+\", name!~\"cadvisor|alloy\"} > 0",
          "legendFormat": "{{name}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
