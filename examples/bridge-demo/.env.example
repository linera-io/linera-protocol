# Linera network
LINERA_FAUCET_URL=http://localhost:8080

# Linera application IDs (from setup.sh output)
LINERA_APPLICATION_ID=<wrapped-fungible-app-id>
LINERA_BRIDGE_APP_ID=<evm-bridge-app-id>

# Relay server
LINERA_RELAY_URL=http://localhost:3001

# EVM contract addresses (from setup.sh output)
LINERA_BRIDGE_ADDRESS=<FungibleBridge-address>
LINERA_TOKEN_ADDRESS=<MockERC20-address>

# Bridge chain ID (relay's chain, for withdrawal targets)
LINERA_BRIDGE_CHAIN_ID=<bridge-chain-id>
