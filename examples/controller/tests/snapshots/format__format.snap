                  TYPENAME: ChainId
      6:
        RemoveChain:
          STRUCT:
            - chain_id:
                TYPENAME: ChainId
      7:
        UpdateAllChains:
          STRUCT:
            - chains:
                SEQ:
                  TUPLE:
                    - TYPENAME: ChainId
                    - SEQ:
                        TYPENAME: ChainId
  DataBlobHash:
    NEWTYPESTRUCT:
      TYPENAME: CryptoHash
  Message:
    ENUM:
      0:
        ExecuteWorkerCommand:
          STRUCT:
            - owner:
                TYPENAME: AccountOwner
            - command:
                TYPENAME: WorkerCommand
      1:
        ExecuteControllerCommand:
          STRUCT:
            - admin:
                TYPENAME: AccountOwner
            - command:
                TYPENAME: ControllerCommand
      2:
        Reset: UNIT
