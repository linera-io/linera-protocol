        Start:
          STRUCT:
            - service_id:
                TYPENAME: DataBlobHash
            - owners_to_remove:
                SEQ:
                  TYPENAME: AccountOwner
            - start_height:
                OPTION:
                  TYPENAME: BlockHeight
      4:
        Stop:
          STRUCT:
            - service_id:
                TYPENAME: DataBlobHash
            - new_owners:
                SEQ:
                  TYPENAME: AccountOwner
      5:
        FollowChain:
          STRUCT:
            - chain_id:
                TYPENAME: ChainId
      6:
        ForgetChain:
          STRUCT:
            - chain_id:
                TYPENAME: ChainId
      7:
        AddOwners:
