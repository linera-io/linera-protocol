---
source: native-fungible/src/service.rs
expression: service.schema().sdl()
---
type AccountEntry {
	key: AccountOwner!
	value: Amount!
}

"""
A unique identifier for a user or an application.
"""
scalar AccountOwner

type Accounts {
	entry(key: AccountOwner!): AccountEntry!
	entries: [AccountEntry!]!
	keys: [AccountOwner!]!
}

"""
A non-negative amount of tokens.
"""
scalar Amount

"""
The unique identifier (UID) of a chain. This is currently computed as the hash value of a ChainDescription.
"""
scalar ChainId

"""
An account.
"""
input FungibleAccount {
	"""
	Chain ID of the account
	"""
	chainId: ChainId!
	"""
	Owner of the account
	"""
	owner: AccountOwner!
}

type NativeFungibleOperationMutationRoot {
	balance(owner: AccountOwner!): [Int!]!
	tickerSymbol: [Int!]!
	transfer(owner: AccountOwner!, amount: Amount!, targetAccount: FungibleAccount!): [Int!]!
	claim(sourceAccount: FungibleAccount!, amount: Amount!, targetAccount: FungibleAccount!): [Int!]!
}

type NativeFungibleTokenService {
	tickerSymbol: String!
	accounts: Accounts!
}

"""
Directs the executor to include this field or fragment only when the `if` argument is true.
"""
directive @include(if: Boolean!) on FIELD | FRAGMENT_SPREAD | INLINE_FRAGMENT
"""
Directs the executor to skip this field or fragment when the `if` argument is true.
"""
directive @skip(if: Boolean!) on FIELD | FRAGMENT_SPREAD | INLINE_FRAGMENT
schema {
	query: NativeFungibleTokenService
	mutation: NativeFungibleOperationMutationRoot
}
