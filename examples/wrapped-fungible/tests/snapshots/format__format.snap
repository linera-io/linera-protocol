---
source: wrapped-fungible/tests/format.rs
expression: "WrappedFungibleApplication::pruned_formats().unwrap()"
---
REGISTRY:
  Account:
    STRUCT:
      - chain_id:
          TYPENAME: ChainId
      - owner:
          TYPENAME: AccountOwner
  BurnEvent:
    STRUCT:
      - target:
          TUPLEARRAY:
            CONTENT: U8
            SIZE: 20
      - amount: U128
  ChainId:
    NEWTYPESTRUCT:
      TYPENAME: CryptoHash
  FungibleResponse:
    ENUM:
      142627141:
        TickerSymbol:
          NEWTYPE: STR
      206964944:
        Balance:
          NEWTYPE: U128
      211312752:
        Ok: UNIT
  Message:
    ENUM:
      0:
        Credit:
          STRUCT:
            - target:
                TYPENAME: AccountOwner
            - amount: U128
            - source:
                TYPENAME: AccountOwner
      1:
        Withdraw:
          STRUCT:
            - owner:
                TYPENAME: AccountOwner
            - amount: U128
            - target_account:
                TYPENAME: Account
  WrappedFungibleOperation:
    ENUM:
      142627141:
        TickerSymbol: UNIT
      144297355:
        Transfer:
          STRUCT:
            - owner:
                TYPENAME: AccountOwner
            - amount: U128
            - target_account:
                TYPENAME: Account
      158617459:
        Approve:
          STRUCT:
            - owner:
                TYPENAME: AccountOwner
            - spender:
                TYPENAME: AccountOwner
            - allowance: U128
      170732950:
        RegisterAuthorizedCaller:
          STRUCT:
            - app_id:
                TYPENAME: ApplicationId
      198295567:
        MintAndTransfer:
          STRUCT:
            - target_account:
                TYPENAME: Account
            - amount: U128
      204322437:
        Claim:
          STRUCT:
            - source_account:
                TYPENAME: Account
            - amount: U128
            - target_account:
                TYPENAME: Account
      206964944:
        Balance:
          STRUCT:
            - owner:
                TYPENAME: AccountOwner
      214048906:
        TransferFrom:
          STRUCT:
            - owner:
                TYPENAME: AccountOwner
            - spender:
                TYPENAME: AccountOwner
            - amount: U128
            - target_account:
                TYPENAME: Account
      239329758:
        Burn:
          STRUCT:
            - owner:
                TYPENAME: AccountOwner
            - amount: U128
  WrappedParameters:
    STRUCT:
      - ticker_symbol: STR
      - decimals: U8
      - mint_chain_id:
          TYPENAME: ChainId
      - evm_token_address:
          TUPLEARRAY:
            CONTENT: U8
            SIZE: 20
      - evm_source_chain_id: U64
OPERATION:
  TYPENAME: WrappedFungibleOperation
RESPONSE:
  TYPENAME: FungibleResponse
MESSAGE:
  TYPENAME: Message
EVENT_VALUE:
  TYPENAME: BurnEvent
