	transfer(owner: AccountOwner!, amount: Amount!, targetAccount: Account!): [Int!]!
	transferFrom(owner: AccountOwner!, spender: AccountOwner!, amount: Amount!, targetAccount: Account!): [Int!]!
	claim(sourceAccount: Account!, amount: Amount!, targetAccount: Account!): [Int!]!
}

