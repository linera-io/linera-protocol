---
source: fungible/tests/format.rs
expression: "FungibleApplication::pruned_formats().unwrap()"
---
REGISTRY:
  Account:
    STRUCT:
      - chain_id:
          TYPENAME: ChainId
      - owner:
          TYPENAME: AccountOwner
  ChainId:
    NEWTYPESTRUCT:
      TYPENAME: CryptoHash
  FungibleOperation:
    ENUM:
      0:
        Balance:
          STRUCT:
            - owner:
                TYPENAME: AccountOwner
      1:
        TickerSymbol: UNIT
      2:
        Approve:
          STRUCT:
            - owner:
                TYPENAME: AccountOwner
            - spender:
                TYPENAME: AccountOwner
            - allowance: U128
      3:
        Transfer:
          STRUCT:
            - owner:
                TYPENAME: AccountOwner
            - amount: U128
            - target_account:
                TYPENAME: Account
      4:
        TransferFrom:
          STRUCT:
            - owner:
                TYPENAME: AccountOwner
            - spender:
                TYPENAME: AccountOwner
            - amount: U128
            - target_account:
                TYPENAME: Account
      5:
        Claim:
          STRUCT:
            - source_account:
                TYPENAME: Account
            - amount: U128
            - target_account:
                TYPENAME: Account
  FungibleResponse:
    ENUM:
      0:
        Ok: UNIT
      1:
        Balance:
          NEWTYPE: U128
      2:
        TickerSymbol:
          NEWTYPE: STR
  InitialState:
    STRUCT:
      - accounts:
          MAP:
            KEY:
              TYPENAME: AccountOwner
            VALUE: U128
  Message:
    ENUM:
      0:
        Credit:
          STRUCT:
            - target:
                TYPENAME: AccountOwner
            - amount: U128
            - source:
                TYPENAME: AccountOwner
      1:
        Withdraw:
          STRUCT:
            - owner:
                TYPENAME: AccountOwner
            - amount: U128
            - target_account:
                TYPENAME: Account
  Parameters:
    STRUCT:
      - ticker_symbol: STR
      - decimals: U8
OPERATION:
  TYPENAME: FungibleOperation
RESPONSE:
  TYPENAME: FungibleResponse
MESSAGE:
  TYPENAME: Message
EVENT_VALUE: UNIT
