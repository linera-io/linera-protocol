export EVM_PRIVATE_KEY=0x9a20111ed58ec1cba0832db13034e6b1e004cc1df91f13f29a32de17d6342da9                         # funded deployer key

# Governance roles (EVM addresses you control)
export PAUSE_GUARDIAN=0x7198271BB49C890bc2B188482AD9c94c5F25DB86
export PROPOSER=0x4B86c39c6f486F5AA5457e576b603Ed7edE5E3F2
